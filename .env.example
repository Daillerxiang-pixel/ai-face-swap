# AI换图 — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ⚠️ .env 文件不会被提交到 Git

# ---- 服务配置 ----
NODE_ENV=production
PORT=8080

# ---- 腾讯云人脸融合 API ----
TENCENT_SECRET_ID=你的腾讯云SecretId
TENCENT_SECRET_KEY=你的腾讯云SecretKey
TENCENT_ACTIVITY_ID=at_xxxxxxxxxx

# ---- Akool 换脸（异步，需公网 URL — 通常配合 OSS）----
# https://docs.akool.com/ai-tools-suite/faceswap
AKOOL_API_KEY=

# ---- Replicate API（备用 AI 引擎）----
REPLICATE_API_TOKEN=r8_xxxxxxxxxx

# ---- JWT 密钥（用于用户登录 Token）----
JWT_SECRET=请生成一个随机字符串_至少32位

# ---- 阿里云 OSS（对象存储）----
# 不配置或 Bucket 名无效则回退到本地存储（仅文件名，不要填 URL）
# Bucket 须为小写字母/数字/连字符，3–63 字符；勿填 https://... 整段域名
OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
OSS_BUCKET=aihuantu
OSS_REGION=oss-cn-beijing
# 区域级 Endpoint（与控制台「Endpoint 地域节点」一致，不要填带 bucket 子域名的访问域名）
# OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
# 临时只存本地、跳过 OSS 上传时设为 1（头像/换脸仍可保存，URL 为站点 /uploads/...）
# SKIP_OSS_UPLOAD=1
# 设为 1 时：OSS 未正确配置则进程直接退出（适合生产强制走 OSS）
# REQUIRE_OSS=1
# 可选；控制台里的「访问域名」仅作参考，代码按 BUCKET + REGION 拼接
# OSS_ENDPOINT=https://aihuantu.oss-cn-beijing.aliyuncs.com

# 仅用于 API 返回中的图片/视频展示 URL（与 Bucket 公网一致）。当 OSS SDK 未启用但对象已在 Bucket 内时，避免只返回 /uploads 导致正式服磁盘无文件而 404。
# OSS_PUBLIC_BASE_URL=https://aihuantu.oss-cn-beijing.aliyuncs.com

# ---- 上传配置 ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
