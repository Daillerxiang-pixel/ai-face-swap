# AI换图 — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ⚠️ .env 文件不会被提交到 Git

# ---- 服务配置 ----
NODE_ENV=production
PORT=8080

# ---- 腾讯云人脸融合 API ----
TENCENT_SECRET_ID=你的腾讯云SecretId
TENCENT_SECRET_KEY=你的腾讯云SecretKey
TENCENT_ACTIVITY_ID=at_xxxxxxxxxx

# ---- Replicate API（备用 AI 引擎）----
REPLICATE_API_TOKEN=r8_xxxxxxxxxx

# ---- JWT 密钥（用于用户登录 Token）----
JWT_SECRET=请生成一个随机字符串_至少32位

# ---- 阿里云 OSS（对象存储）----
# 不配置则回退到本地存储
OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
OSS_BUCKET=你的Bucket名称
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=https://你的Bucket.oss-cn-beijing.aliyuncs.com

# ---- 上传配置 ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
